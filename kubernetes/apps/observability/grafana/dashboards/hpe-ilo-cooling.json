{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Overview",
      "url": "/d/hpe-ilo-overview/?${__url_time_range}&${__all_variables}"
    },
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Power & Thermal",
      "url": "/d/hpe-ilo-power-thermal/?${__url_time_range}&${__all_variables}"
    },
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Cooling",
      "url": "/d/hpe-ilo-cooling/?${__url_time_range}&${__all_variables}"
    },
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Memory",
      "url": "/d/hpe-ilo-memory/?${__url_time_range}&${__all_variables}"
    },
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Compute",
      "url": "/d/hpe-ilo-compute/?${__url_time_range}&${__all_variables}"
    },
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Storage",
      "url": "/d/hpe-ilo-storage/?${__url_time_range}&${__all_variables}"
    },
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "title": "Network",
      "url": "/d/hpe-ilo-network/?${__url_time_range}&${__all_variables}"
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Fan speed",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 300,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "type": "timeseries",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "title": "Fan speed (% of max RPM)",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_rpm_percentage{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Fan health & state",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 301,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "OK",
                  "color": "green"
                },
                "2": {
                  "text": "Warning",
                  "color": "yellow"
                },
                "3": {
                  "text": "Critical",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 2,
      "type": "stat",
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "title": "Fan health",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_health{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "Enabled",
                  "color": "green"
                },
                "2": {
                  "text": "Disabled",
                  "color": "text"
                },
                "3": {
                  "text": "Standby offline",
                  "color": "blue"
                },
                "4": {
                  "text": "Standby spare",
                  "color": "blue"
                },
                "5": {
                  "text": "In test",
                  "color": "blue"
                },
                "6": {
                  "text": "Starting",
                  "color": "blue"
                },
                "7": {
                  "text": "Absent",
                  "color": "text"
                },
                "8": {
                  "text": "Unavailable offline",
                  "color": "orange"
                },
                "9": {
                  "text": "Deferring",
                  "color": "yellow"
                },
                "10": {
                  "text": "Quiesced",
                  "color": "blue"
                },
                "11": {
                  "text": "Updating",
                  "color": "blue"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "text",
                "value": 2
              },
              {
                "color": "orange",
                "value": 8
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 3,
      "type": "stat",
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "title": "Fan state",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_state{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "hpe",
    "ilo",
    "fans"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(redfish_up, instance)",
        "includeAll": false,
        "label": "iLO host",
        "multi": false,
        "name": "instance",
        "query": {
          "query": "label_values(redfish_up, instance)",
          "refId": "A"
        },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "HPE iLO \u2014 Cooling",
  "uid": "hpe-ilo-cooling",
  "version": 1
}
