  "panels": [
    {
      "type": "row",
      "title": "Fan speed",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 300,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "type": "timeseries",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "title": "Fan speed (% of max RPM)",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_rpm_percentage{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Fan health & state",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 301,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "1": {
                    "color": "green",
                    "text": "OK"
                  }
                },
                "type": "value"
              },
              {
                "options": {
                  "2": {
                    "color": "yellow",
                    "text": "Warning"
                  }
                },
                "type": "value"
              },
              {
                "options": {
                  "3": {
                    "color": "red",
                    "text": "Critical"
                  }
                },
                "type": "value"
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 2
                },
                {
                  "color": "red",
                  "value": 3
                }
              ]
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 2,
      "type": "stat",
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "title": "Fan health",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_health{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
