{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Down" } }, "type": "value" },
            { "options": { "1": { "color": "green", "text": "Up" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Redfish scrape",
      "type": "stat",
      "targets": [{ "expr": "max(redfish_up{instance=~\"$instance\"})", "legendFormat": "iLO", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "System health",
      "type": "stat",
      "targets": [{ "expr": "max(redfish_system_health_state{instance=~\"$instance\"})", "legendFormat": "odin", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Chassis health",
      "type": "stat",
      "targets": [{ "expr": "max(redfish_chassis_health{instance=~\"$instance\"})", "legendFormat": "Chassis", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "id": 8,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Manager (iLO)",
      "type": "stat",
      "targets": [{ "expr": "max(redfish_manager_health_state{instance=~\"$instance\"})", "legendFormat": "iLO", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Off" } }, "type": "value" },
            { "options": { "1": { "text": "On" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "id": 9,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "System power",
      "type": "stat",
      "targets": [{ "expr": "max(redfish_system_power_state{instance=~\"$instance\"})", "legendFormat": "Host", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "title": "Temperatures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "max by (sensor) (redfish_chassis_temperature_celsius{instance=~\"$instance\"})",
          "legendFormat": "{{sensor}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "watt" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "title": "Chassis power draw",
      "type": "timeseries",
      "targets": [
        {
          "expr": "max(redfish_chassis_power_average_consumed_watts{instance=~\"$instance\"})",
          "legendFormat": "Total chassis",
          "refId": "A"
        },
        {
          "expr": "max by (power_supply_id) (redfish_chassis_power_powersupply_last_power_output_watts{instance=~\"$instance\"})",
          "legendFormat": "PSU {{power_supply_id}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "title": "Fan speed (% of max RPM)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_rpm_percentage{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Power supply health",
      "type": "stat",
      "targets": [
        {
          "expr": "max by (power_supply_id) (redfish_chassis_power_powersupply_health{instance=~\"$instance\"})",
          "legendFormat": "PSU {{power_supply_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Fan health",
      "type": "stat",
      "targets": [
        {
          "expr": "max by (fan) (redfish_chassis_fan_health{instance=~\"$instance\"})",
          "legendFormat": "{{fan}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Processor health",
      "type": "stat",
      "targets": [
        {
          "expr": "max by (processor_id) (redfish_system_processor_health_state{instance=~\"$instance\"})",
          "legendFormat": "CPU {{processor_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "OK" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "Warning" } }, "type": "value" },
            { "options": { "3": { "color": "red", "text": "Critical" } }, "type": "value" }
          ],
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Health" },
            "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 10, "x": 8, "y": 20 },
      "id": 12,
      "options": { "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Drive" }] },
      "title": "Storage drives",
      "type": "table",
      "targets": [
        {
          "expr": "max by (drive, drive_id) (redfish_system_storage_drive_health_state{instance=~\"$instance\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "keepLabels": ["drive", "drive_id"] } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "instance": true, "job": true, "hostname": true, "resource": true, "container": true, "endpoint": true, "namespace": true, "pod": true, "host": true, "system_id": true }, "renameByName": { "Value": "Health", "drive": "Drive", "drive_id": "ID" } } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "gibibytes",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 20 },
      "id": 13,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Installed RAM",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(redfish_system_memory_capacity{instance=~\"$instance\"}) / 1024",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["hpe", "ilo", "redfish", "hardware", "proliant"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(redfish_up, instance)",
        "includeAll": false,
        "label": "iLO host",
        "multi": false,
        "name": "instance",
        "query": { "query": "label_values(redfish_up, instance)", "refId": "A" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HPE iLO / Redfish",
  "uid": "hpe-ilo-redfish",
  "version": 3
}
