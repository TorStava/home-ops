  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "OK"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "2": {
                  "color": "yellow",
                  "text": "Warning"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "3": {
                  "color": "red",
                  "text": "Critical"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "type": "table",
      "options": {
        "showHeader": true,
        "sortBy": []
      },
      "title": "Drive health",
      "targets": [
        {
          "expr": "max by (drive, drive_id) (redfish_system_storage_drive_health_state{instance=~\"$instance\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true,
              "hostname": true,
              "resource": true,
              "container": true,
              "endpoint": true,
              "namespace": true,
              "pod": true,
              "host": true,
              "system_id": true
            },
            "renameByName": {
              "Value": "Health",
              "drive": "Drive",
              "drive_id": "ID"
            }
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "OK"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "2": {
                  "color": "yellow",
                  "text": "Warning"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "3": {
                  "color": "red",
                  "text": "Critical"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "type": "table",
      "options": {
        "showHeader": true,
        "sortBy": []
      },
      "title": "Drive capacity (bytes)",
      "targets": [
        {
          "expr": "max by (drive, drive_id) (redfish_system_storage_drive_capacity{instance=~\"$instance\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true,
              "hostname": true,
              "resource": true,
              "container": true,
              "endpoint": true,
              "namespace": true,
              "pod": true,
              "host": true,
              "system_id": true
            },
            "renameByName": {
              "Value": "Bytes",
              "drive": "Drive",
              "drive_id": "ID"
            }
          }
        }
      ]
    }
  ],
